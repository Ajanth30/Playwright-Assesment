{
  "name": "playwright-assesment",
  "version": "1.0.0",
  "description": "UI, API, and E2E test automation assessment with Playwright",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=e2e",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --headed",
    "test:ui-mode": "playwright test --ui",
    "report": "playwright show-report playwright-report"
  },
  "keywords": ["playwright", "test-automation"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "dotenv": "^17.2.3"
  }
}
